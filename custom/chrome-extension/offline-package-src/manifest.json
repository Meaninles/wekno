{
  "manifest_version": 3,
  "name": "知识管理助手-你的第二大脑，从浏览器开始",
  "version": "1.0.3",
  "key": "",
  "description": "配合微信对话平台的知识管理助手或 WeKnora 的浏览器插件，让你一键剪藏网页、随时提问、Markdown 速记",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "知识管理助手"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["defuddle.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "scripting",
    "contextMenus",
    "tabs",
    "alarms"
  ],
  "web_accessible_resources": [
    {
      "resources": ["auth-callback.html", "auth-callback.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "http://*/*",
      "https://*/*"
    ]
  },
  "commands": {
    "open-sidepanel": {
      "description": "打开侧边栏"
    },
    "quick-ask": {
      "description": "快速提问"
    },
    "select-clip": {
      "description": "选择剪藏"
    },
    "quick-note": {
      "description": "快速笔记"
    },
    "smart-clip": {
      "description": "智能剪藏"
    }
  }
}
