FROM golang:1.26-bookworm

WORKDIR /workspace

# Headless Chromium for the web_fetch tool (chromedp). The web_fetch tool
# launches a real headless browser to render JS-heavy pages; without a browser
# binary the chromedp path fails on every fetch. Chromium needs a few runtime
# libs and fonts to render pages correctly. fonts-noto-cjk covers CJK pages.
RUN apt-get -o Acquire::Retries=3 update && \
    apt-get -o Acquire::Retries=3 install -y --no-install-recommends \
        build-essential \
        ca-certificates \
        git \
        libsqlite3-dev \
        make \
        chromium \
        fonts-noto-cjk \
        fonts-liberation \
        7zip \
        libarchive-tools && \
    rm -rf /var/lib/apt/lists/*

ENV CGO_ENABLED=1
